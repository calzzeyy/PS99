task.spawn(function()
    local RunService = game:GetService("RunService")
    local Lighting = game:GetService("Lighting")

    local originalWaterWave = Workspace.Terrain.WaterWaveSize
    local originalShadows = Lighting.GlobalShadows

    local sessionStartGifts = -1
    local sessionStartHuges = -1
    local sessionStartTitanics = -1
    local wasBoostEnabled = false

    while running do
        task.wait(1)

        local isBoostEnabled = getFpsBoostState()
        if isBoostEnabled ~= wasBoostEnabled then
            wasBoostEnabled = isBoostEnabled
            Overlay.Visible = isBoostEnabled
            pcall(function()
                if isBoostEnabled then
                    if setfpscap then setfpscap(15) end
                    RunService:Set3dRenderingEnabled(false)
                    Lighting.GlobalShadows = false
                    Workspace.Terrain.WaterWaveSize = 0
                else
                    if setfpscap then setfpscap(0) end
                    RunService:Set3dRenderingEnabled(true)
                    Lighting.GlobalShadows = originalShadows
                    Workspace.Terrain.WaterWaveSize = originalWaterWave
                end
            end)
        end

        if isBoostEnabled then
            pcall(function()
                local Client = ReplicatedStorage:WaitForChild("Library"):WaitForChild("Client")
                local Save = require(Client:WaitForChild("Save")).Get()

                local currentGifts = 0
                if Save.Inventory then
                    for _, categoryData in pairs(Save.Inventory) do
                        if type(categoryData) == "table" then
                            for _, itemData in pairs(categoryData) do
                                if type(itemData) == "table" and itemData.id == "Soccer Gift" then
                                    currentGifts = currentGifts + (itemData._am or 1)
                                end
                            end
                        end
                    end
                end

                local currentHuges, currentTitanics = 0, 0
                if Save.Inventory and Save.Inventory.Pet then
                    local petDirectory = require(ReplicatedStorage:WaitForChild("Library"):WaitForChild("Directory"):WaitForChild("Pets"))
                    for _, petData in pairs(Save.Inventory.Pet) do
                        local petInfo = petDirectory[petData.id]
                        if petInfo then
                            if petInfo.huge then currentHuges = currentHuges + (petData._am or 1) end
                            if petInfo.titanic then currentTitanics = currentTitanics + (petData._am or 1) end
                        end
                    end
                end

                if sessionStartGifts == -1 then
                    sessionStartGifts = currentGifts
                    sessionStartHuges = currentHuges
                    sessionStartTitanics = currentTitanics
                end

                local function fmt(n)
                    if n >= 1e9 then return string.format("%.2fB", n/1e9)
                    elseif n >= 1e6 then return string.format("%.2fM", n/1e6)
                    elseif n >= 1e3 then return string.format("%.2fK", n/1e3)
                    else return tostring(n) end
                end

                giftsLbl.Text = "🎁 Soccer Gifts: " .. fmt(currentGifts - sessionStartGifts)
                hugesLbl.Text = "🐾 Huges Hatched: " .. tostring(currentHuges - sessionStartHuges)
                titanicsLbl.Text = "🌌 Titanics Hatched: " .. tostring(currentTitanics - sessionStartTitanics)
            end)
        end
    end

    pcall(function()
        if setfpscap then setfpscap(0) end
        RunService:Set3dRenderingEnabled(true)
        Lighting.GlobalShadows = originalShadows
        Workspace.Terrain.WaterWaveSize = originalWaterWave
    end)
end)

