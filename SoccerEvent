local killConnection
killConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.P then
        running = false
        if ScreenGui then ScreenGui:Destroy() end
        if OverlayGui then OverlayGui:Destroy() end
        if killConnection then killConnection:Disconnect() end

        pcall(function()
            if setfpscap then setfpscap(0) end
            local RunService = game:GetService("RunService")
            RunService:Set3dRenderingEnabled(true)
            local Lighting = game:GetService("Lighting")
            Lighting.GlobalShadows = true
            Workspace.Terrain.WaterWaveSize = 0.05
        end)
        print("[Soccer Event] Script terminated. 3D rendering restored.")
    end
end)

