-- The remotes we need
local SendPositionRemote = ReplicatedStorage:WaitForChild("Network"):WaitForChild("Send Position")
local CustomEggsHatchRemote = ReplicatedStorage:WaitForChild("Network"):WaitForChild("CustomEggs_Hatch")

-- The teleport CFrames (as provided)
local teleportCFrames = {
    CFrame.new(1427.0546875, 16.664621353149414, -32055.990234375, 0.9399377703666687, 7.914940169939655e-08, -0.34134581685066223, -4.9242501631852065e-08, 1, 9.627922992194726e-08, 0.34134581685066223, -7.368775811755768e-08, 0.9399377703666687),
    CFrame.new(1427.3909912109375, 33.35685729980469, -32027.845703125, 0.9999285936355591, -0.00567561574280262, 0.010514963418245316, 0, 0.8799915909767151, 0.47498923540115356, -0.011948935687541962, -0.47495532035827637, 0.8799287676811218),
    CFrame.new(1427.0546875, 18.164621353149414, -32055.990234375, 1, 0, 0, 0, 1, 0, 0, 0, 1)
}

-- Egg hash and amount
local EGG_HASH = "b2216c4617f84f87ab097b8a6bedb5d2"
local MAX_OPENS = 5

task.spawn(function()
    while running do
        task.wait(0.2)
        if getHatchState() then
            _G.isHatching = true
            pcall(function()
                local char = Players.LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if not root then return end

                -- Save current position so we can return later if desired
                local originalCFrame = root.CFrame

                -- Teleport to the egg using Send Position
                SendPositionRemote:FireServer(unpack(teleportCFrames))
                task.wait(0.1) -- let the server register

                -- Now hatch max eggs
                CustomEggsHatchRemote:InvokeServer(EGG_HASH, MAX_OPENS)

                -- Wait 5 seconds before next hatch
                task.wait(5.0)

                -- Return to the farm spot (optional, but safe)
                if _G.sweepCenterCFrame and getShootState() then
                    root.CFrame = _G.sweepCenterCFrame
                else
                    root.CFrame = originalCFrame
                end
            end)
            _G.isHatching = false
        else
            _G.isHatching = false
        end
    end
end)

