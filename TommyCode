-- ==========================================
-- NO EGG ANIMATION LOOP
-- ==========================================
task.spawn(function()
    local EggsModule = Players.LocalPlayer.PlayerScripts.Scripts.Game:FindFirstChild("Egg Opening Frontend")
    local originalAnim = nil
    if EggsModule then
        pcall(function() originalAnim = getsenv(EggsModule).PlayEggAnimation end)
    end
    
    local wasNoAnim = false
    while running do
        task.wait(1)
        if getNoAnimState() then
            if not wasNoAnim and EggsModule then
                pcall(function() getsenv(EggsModule).PlayEggAnimation = function() return end end)
                wasNoAnim = true
            end
        else
            if wasNoAnim and EggsModule and originalAnim then
                pcall(function() getsenv(EggsModule).PlayEggAnimation = originalAnim end)
                wasNoAnim = false
            end
        end
    end
    
    if wasNoAnim and EggsModule and originalAnim then
        pcall(function() getsenv(EggsModule).PlayEggAnimation = originalAnim end)
    end
end)

-- ==========================================
-- KILLSWITCH (PRESS 'L' TO QUIT)
-- ==========================================
local UserInputService = game:GetService("UserInputService")
local killConnection

killConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.L then
        running = false
        
        if ScreenGui then ScreenGui:Destroy() end
        if OverlayGui then OverlayGui:Destroy() end
        
        if killConnection then killConnection:Disconnect() end
        
        pcall(function()
            if setfpscap then setfpscap(0) end
            local RunService = game:GetService("RunService")
            local Lighting = game:GetService("Lighting")
            RunService:Set3dRenderingEnabled(true)
            Lighting.GlobalShadows = true
            Workspace.Terrain.WaterWaveSize = 0.05
        end)
        
        print("[Soccer Event] Script terminated and 3D rendering restored.")
    end
end)
