-- ==========================================
-- AUTO COLLECT ORBS LOOP
-- ==========================================
_G.isHatching = false 

task.spawn(function()
    while running do
        task.wait(0.1)
        if getOrbsState() and not _G.isHatching then
            pcall(function()
                local root = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if not root then return end

                if not _G.sweepCenterCFrame then
                    _G.sweepCenterCFrame = root.CFrame
                end
                
                local debris = Workspace:FindFirstChild("__DEBRIS")
                if not debris then return end
                
                local foundOrbs = false
                
                for _, category in ipairs(debris:GetChildren()) do
                    for _, orb in ipairs(category:GetChildren()) do
                        if not running or not getOrbsState() or _G.isHatching then 
                            _G.isCollectingOrb = false
                            return 
                        end
                        
                        if string.find(string.lower(orb.Name), "orb") and orb:IsA("BasePart") then
                            _G.isCollectingOrb = true
                            root.CFrame = orb.CFrame
                            foundOrbs = true
                            task.wait(0.05)
                            pcall(function() orb:Destroy() end)
                        end
                    end
                end
                
                _G.isCollectingOrb = false
                
                if foundOrbs and _G.sweepCenterCFrame and not _G.isHatching then
                    root.CFrame = _G.sweepCenterCFrame
                    for i = 1, 10 do
                        task.wait(0.1)
                        if not running or not getOrbsState() then break end
                    end
                end
            end)
        else
            _G.sweepCenterCFrame = nil
        end
    end
end)

-- ==========================================
-- AUTO HATCH CUSTOM EGG LOOP (maxHatch = 50)
-- ==========================================
local VirtualInputManager = game:GetService("VirtualInputManager")

task.spawn(function()
    local Network = ReplicatedStorage:WaitForChild("Network")
    local CustomHatch = Network:WaitForChild("CustomEggs_Hatch")
    
    while running do
        task.wait(0.1)
        if getHatchState() then
            pcall(function()
                local root = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if not root then return end
                
                local targetCFrame = nil
                local targetEggHash = nil
                local shortestDistance = math.huge
                
                local things = Workspace:FindFirstChild("__THINGS")
                if things then
                    local function checkEggs(folder)
                        if not folder then return end
                        for _, egg in ipairs(folder:GetChildren()) do
                            if egg:IsA("Model") then
                                local pivot = egg:GetPivot()
                                local distance = (pivot.Position - root.Position).Magnitude
                                if distance < shortestDistance then
                                    shortestDistance = distance
                                    targetCFrame = pivot
                                    targetEggHash = egg.Name
                                end
                            end
                        end
                    end
                    
                    checkEggs(things:FindFirstChild("CustomEggs"))
                    checkEggs(things:FindFirstChild("Eggs"))
                end
                
                local originalCFrame = root.CFrame
                
                if targetCFrame then
                    _G.isHatching = true
                    root.CFrame = targetCFrame * CFrame.new(0, 0, 8)
                    task.wait(0.2)
                else
                    warn("[Soccer Event] Could not find physical Egg.")
                end
                
                -- ✅ SET YOUR MAX HATCH HERE (you said 50)
                local maxHatch = 50
                
                if not targetEggHash then return end
                
                local args = { targetEggHash, maxHatch }
                
                task.spawn(function()
                    local success = CustomHatch:InvokeServer(unpack(args))
                    if success then
                        local cam = Workspace.CurrentCamera
                        local clickX = cam.ViewportSize.X - 5
                        local clickY = cam.ViewportSize.Y / 2
                        local clickEndTime = tick() + 2.0
                        while tick() < clickEndTime do
                            VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, true, game, 1)
                            task.wait(0.01)
                            VirtualInputManager:SendMouseButtonEvent(clickX, clickY, 0, false, game, 1)
                            task.wait(0.01)
                        end
                    end
                end)
                
                if targetCFrame then
                    root.CFrame = originalCFrame 
                    _G.isHatching = false
                    task.wait(1.0)
                end
            end)
        end
    end
end)

